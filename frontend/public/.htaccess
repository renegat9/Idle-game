Options -MultiViews +SymLinksIfOwnerMatch
DirectoryIndex index.html

RewriteEngine On
RewriteBase /

# Requêtes API → répertoire api/ contient un gateway PHP vers laravel/public
RewriteRule ^api - [L,NC]

# Ne pas réécrire les fichiers/dossiers existants (assets, storage, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Toutes les routes SPA → index.html
RewriteRule ^ index.html [QSA,L]
